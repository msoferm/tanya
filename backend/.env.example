# ===== שרת =====
PORT=5001
CORS_ORIGIN=http://localhost:5174

# ===== מסד נתונים PostgreSQL =====
DB_HOST=localhost
DB_PORT=5433
DB_NAME=tanya_leads
DB_USER=tanya_user
DB_PASSWORD=tanya_secret_2024

# ===== אבטחה =====
# מפתח חתימה ל-JWT - חובה לשנות בפרודקשן למחרוזת אקראית ארוכה
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=12h

# טוקן סודי שאיתו טופס האלמנטור / וובהוקים מזדהים מול המערכת
WEBHOOK_TOKEN=change_this_webhook_token

# ===== WooCommerce =====
# כתובת אתר ה-WordPress (ללא / בסוף)
WC_URL=https://your-academy-site.co.il
# מפתחות REST API מתוך WooCommerce > Settings > Advanced > REST API
WC_CONSUMER_KEY=ck_xxxxxxxxxxxxxxxxxxxxxxxx
WC_CONSUMER_SECRET=cs_xxxxxxxxxxxxxxxxxxxxxxxx

# ===== שליחת מיילים (SMTP) =====
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your_app_password
MAIL_FROM=אקדמיה לתניא <your-email@gmail.com>
